{
    "name": "philicevic/pesto",
    "description": "A Pest plugin for more pleasant testing in TYPO3 — Unit, Functional and Feature tests with idiomatic Pest APIs.",
    "type": "pest-plugin",
    "license": "MIT",
    "keywords": ["pest", "typo3", "testing", "pest-plugin", "phpunit"],
    "authors": [
        {
            "name": "Philipp Ehrenberg",
            "email": "ehrenberg.ph@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "pestphp/pest": "^4.0",
        "typo3/cms-core": "^13.0",
        "typo3/testing-framework": "^9.0",
        "psr/http-message": "^1.0 || ^2.0"
    },
    "require-dev": {
        "pestphp/pest-plugin-type-coverage": "^4.0",
        "phpstan/phpstan": "^1.10"
    },
    "autoload": {
        "psr-4": {
            "Philicevic\\Pesto\\": "src/"
        },
        "files": [
            "src/Pest/Functions.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Philicevic\\Pesto\\Tests\\": "tests/"
        }
    },
    "extra": {
        "pest": {
            "plugins": [
                "Philicevic\\Pesto\\Plugin"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "typo3/class-alias-loader": true,
            "typo3/cms-composer-installers": true
        }
    },
    "minimum-stability": "stable"
}
